# .env.template
# -----------------------------------------
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains API secrets.
# .env is listed in .gitignore.
#
# Flask configuration
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_APP=run.py
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:5000

# Database (leave blank for SQLite dev default)
# DATABASE_URL=postgresql://user:password@localhost/vigil_prod

# LLM API Keys — required for query simulation and fact-checking
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GOOGLE_API_KEY=AIza...

# Magic-link + session settings
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_HOURS=72
MAX_QUERIES_PER_RUN=100

# Email alerts for compliance notifications

POWERAUTOMATE_EMAIL_API_URL=...